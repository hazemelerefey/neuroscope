# NeuroScope Gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
frontend/dist/
frontend/build/

# Environment
.env
.env.local
.env.*.local

# Model files (large — models are now JSON configs, not binary files)
data/samples/*.onnx
data/samples/*.pt
data/samples/*.pth
data/samples/*.h5
data/samples/*.keras
data/samples/*.tflite

# Generated reports
reports/*.pdf
reports/*.html
reports/figures/*.png
reports/figures/*.svg

# Generated notebooks (from export)
*.ipynb_checkpoints/
export_output/

# Docker
.docker/

# Logs
*.log

# Temporary
.tmp/
tmp/
