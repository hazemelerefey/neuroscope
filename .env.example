# NeuroScope Environment Configuration
# Copy this file to .env and adjust values for your environment.

# ──── Service Ports ────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ──── Frontend ────
# URL the frontend uses to reach the backend API
VITE_API_URL=http://localhost:8000

# ──── Backend ────
# Runtime environment: development | production | staging
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Logging level: debug | info | warning | error
LOG_LEVEL=info

# Maximum upload file size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# ──── Production Only ────
# Uncomment and set for production deployments
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
