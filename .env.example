# NeuroScope Environment Configuration
# Copy this file to .env and adjust values for your environment.

# ──── Service Ports ────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ──── Frontend ────
# URL the frontend uses to reach the backend API
VITE_API_URL=http://localhost:8000

# ──── Backend ────
# Runtime environment: development | production | staging
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Logging level: debug | info | warning | error
LOG_LEVEL=info

# ──── Export Settings ────
# Maximum notebook file size in bytes (default: 10MB)
MAX_NOTEBOOK_SIZE=10485760

# Maximum YAML config file size in bytes (default: 1MB)
MAX_YAML_SIZE=1048576

# ──── Production Only ────
# Uncomment and set for production deployments
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
